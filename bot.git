if __name__ == "__main__":
    load_users()
    logger.info("=" * 50)
    logger.info("🚀 БОТ ЗАПУЩЕН И ГОТОВ К РАБОТЕ")
    logger.info(f"👑 Админ: @{ADMIN_USERNAME} (ID: {ADMIN_ID})")
    logger.info(f"👥 Игроков в базе: {len(_users)}")
    logger.info(f"📱 Генерация: {len(BRANDS)*len(MODEL_TYPES)*len(MODIFIERS):,}+ моделей")
    logger.info("=" * 50)
    
    # Бесконечный перезапуск при падениях
    while True:
        try:
            bot.infinity_polling(skip_pending=True, timeout=30, long_polling_timeout=30)
        except Exception as e:
            logger.exception(f"💥 Ошибка polling: {e}")
            logger.info("🔄 Перезапуск через 15 секунд...")
            time.sleep(15)
