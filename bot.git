# --- ОБРАБОТЧИК ИГРОВЫХ CALLBACK ---
@bot.callback_query_handler(func=lambda call: True)
def game_callback(call):
    """Единый обработчик для всех игровых callback"""
    user_id = call.from_user.id
    data = call.data
    
    # Админские callback уже обрабатываются в admin_callback
    if data.startswith("admin_"):
        return
    
    # Подтверждаем получение
    bot.answer_callback_query(call.id)
    
    # Обработка игровых действий
    if data == "game_flip":
        simulate_flip(call.message)
    elif data == "game_shop":
        show_shop_menu(call.message.chat.id)
    elif data == "game_inventory":
        show_inventory(call.message)
    elif data == "game_profile":
        show_profile(call.message)
    elif data == "game_top":
        show_top(call.message)
    elif data == "game_save":
        save_progress_command(call.message)
    elif data == "back_to_main":
        start_cmd(call.message)
    elif data.startswith("buy_"):
        process_buy(call.message, data.replace("buy_", ""))
    elif data.startswith("sell_"):
        try:
            idx = int(data.replace("sell_", ""))
            process_sell_by_idx(call.message, idx)
        except:
            pass
    elif data.startswith("inv_page_"):
        page = int(data.replace("inv_page_", ""))
        show_inventory(call.message, page)

def simulate_flip(m):
    """Обрабатывает флип"""
    user = get_user(m)
    
    can, remaining = can_flip(user)
    if not can:
        bot.send_message(m.chat.id, f"⏳ Флип через: *{remaining}*")
        return
    
    # Выбираем редкость
    rarities = list(RARITY_CONFIG.keys())
    weights = [RARITY_CONFIG[r]["weight"] for r in rarities]
    chosen_rarity = random.choices(rarities, weights=weights)[0]
    
    # Генерируем телефон
    phone_name = generate_phone()
    price_range = RARITY_CONFIG[chosen_rarity]["price_range"]
    base_price = random.randint(price_range[0], price_range[1])
    
    condition = random.choice(COND_NAMES)
    mult = COND_MULT[condition]
    final_price = int(base_price * mult)
    
    user["inventory"].append({
        "name": phone_name,
        "price": final_price,
        "cond": condition
    })
    user["last_flip"] = int(time.time())
    lvl_up = add_exp(user, RARITY_CONFIG[chosen_rarity]["exp"])
    save_users()
    
    phrase = random.choice(PHRASES)
    msg = (
        f"{phrase}\n\n"
        f"📱 *{phone_name}*\n"
        f"🏷️ Редкость: {chosen_rarity.title()}\n"
        f"📊 {condition}\n"
        f"💰 *{final_price:,}$*\n\n"
        f"✅ Добавлен в инвентарь"
    )
    
    if lvl_up:
        msg += "\n\n🏆 *УРОВЕНЬ ПОВЫШЕН!*"
    
    # Шанс на двойной флип (2%)
    if random.random() < 0.02:
        time.sleep(1)
        second_rarity = random.choices(rarities, weights=weights)[0]
        second_name = generate_phone()
        second_range = RARITY_CONFIG[second_rarity]["price_range"]
        second_base = random.randint(second_range[0], second_range[1])
        second_cond = random.choice(COND_NAMES)
        second_mult = COND_MULT[second_cond]
        second_final = int(second_base * second_mult)
        
        user["inventory"].append({
            "name": second_name,
            "price": second_final,
            "cond": second_cond
        })
        save_users()
        msg += f"\n\n🎊 *ДВОЙНОЙ ФЛИП!*\n📱 +{second_name} ({second_cond}) — *{second_final:,}$*"
    
    bot.send_message(m.chat.id, msg)

def process_buy(m, item):
    """Обрабатывает покупку"""
    user = get_user(m)
    
    if item == "case":
        cost = 5000
        if user["balance"] < cost:
            bot.send_message(m.chat.id, f"❌ Нужно {cost:,}$")
            return
        
        name, final_price, condition = generate_case_phone()
        
        user["balance"] -= cost
        user["inventory"].append({
            "name": name,
            "price": final_price,
            "cond": condition
        })
        add_exp(user, 15)
        save_users()
        
        bot.send_message(
            m.chat.id,
            f"🎁 *Кейс*\n📱 *{name}*\n{condition}\n💰 *{final_price:,}$*"
        )
        return
    
    if item in RARITY_CONFIG:
        cost = RARITY_PRICES[item]
        if user["balance"] < cost:
            bot.send_message(m.chat.id, f"❌ Нужно {cost:,}$")
            return
        
        phone_name = generate_phone()
        price_range = RARITY_CONFIG[item]["price_range"]
        base_price = random.randint(price_range[0], price_range[1])
        
        # Для магазина ограничим состояния
        available_conds = ["🆕 Новое", "✨ Идеальное", "✅ Хорошее", "🤔 Потрепанное"]
        weights = [5, 15, 60, 20]
        condition = random.choices(available_conds, weights=weights)[0]
        
        mult = COND_MULT[condition]
        final_price = int(base_price * mult)
        
        user["balance"] -= cost
        user["inventory"].append({
            "name": phone_name,
            "price": final_price,
            "cond": condition
        })
        add_exp(user, RARITY_CONFIG[item]["exp"])
        save_users()
        
        bot.send_message(
            m.chat.id,
            f"🛍️ *Покупка*\n📱 *{phone_name}*\n🏷️ {item.title()}\n{condition}\n💰 *{final_price:,}$*"
        )
        return
    
    bot.send_message(m.chat.id, "❌ Товар не найден")

def show_inventory(m, page=1):
    """Показывает инвентарь с пагинацией"""
    user = get_user(m)
    inv = user.get("inventory", [])
    
    if not inv:
        bot.send_message(m.chat.id, "📱 У тебя нет телефонов")
        return
    
    # Сортируем по цене
    sorted_inv = sorted(inv, key=lambda x: x['price'], reverse=True)
    
    # Пагинация
    per_page = 10
    total_pages = (len(sorted_inv) + per_page - 1) // per_page
    page = max(1, min(page, total_pages))
    
    start = (page - 1) * per_page
    end = min(start + per_page, len(sorted_inv))
    
    total_value = sum(item['price'] for item in inv)
    
    msg = f"📱 *ТВОЙ СКЛАД (LVL {user['lvl']})*\n\n"
    
    for i in range(start, end):
        item = sorted_inv[i]
        # Обрезаем длинные названия
        short_name = item['name'][:30] + "..." if len(item['name']) > 30 else item['name']
        msg += f"*{i+1}.* {short_name}\n   {item['cond']} — *{item['price']:,}$*\n"
    
    msg += f"\n💰 *Всего:* {total_value:,}$"
    msg += f"\n📄 Стр. {page}/{total_pages}"
    msg += "\n\n`продать [номер]`"
    
    # Кнопки навигации
    if total_pages > 1:
        markup = types.InlineKeyboardMarkup()
        if page > 1:
            markup.add(types.InlineKeyboardButton("◀ Назад", callback_data=f"inv_page_{page-1}"))
        if page < total_pages:
            markup.add(types.InlineKeyboardButton("Вперед ▶", callback_data=f"inv_page_{page+1}"))
        bot.send_message(m.chat.id, msg, reply_markup=markup)
    else:
        bot.send_message(m.chat.id, msg)

def show_profile(m):
    """Показывает профиль"""
    user = get_user(m)
    can, remaining = can_flip(user)
    flip_status = "✅ Доступен" if can else f"⏳ Через: {remaining}"
    total_value = sum(item['price'] for item in user['inventory'])
    
    # Прогресс уровня
    next_lvl_xp = user['lvl'] * 150
    progress = int((user['exp'] / next_lvl_xp) * 10) if next_lvl_xp > 0 else 0
    progress_bar = "█" * progress + "░" * (10 - progress)
    
    msg = (
        f"👤 *{user['name']}*\n\n"
        f"💰 *Баланс:* {user['balance']:,}$\n"
        f"📦 *Инвентарь:* {len(user['inventory'])} шт. (💎 {total_value:,}$)\n"
        f"⭐ *Уровень:* {user['lvl']} [{progress_bar}] {user['exp']}/{next_lvl_xp} XP\n"
        f"🎰 *Флип:* {flip_status}"
    )
    bot.send_message(m.chat.id, msg)

def show_top(m):
    """Показывает топ игроков"""
    top = sorted(_users.values(), key=lambda x: x['balance'], reverse=True)[:10]
    res = "🏆 *ТОП 10 БОГАТЫХ ПЕРЕКУПОВ:*\n\n"
    
    for i, u in enumerate(top, 1):
        inv_value = sum(item['price'] for item in u.get('inventory', []))
        medal = "🥇" if i == 1 else "🥈" if i == 2 else "🥉" if i == 3 else f"{i}."
        res += f"{medal} {u['name']} — *{u['balance']:,}$* (💎 {inv_value:,}$) LVL {u['lvl']}\n"
    
    bot.send_message(m.chat.id, res)

@bot.message_handler(func=lambda m: m.text and m.text.lower().startswith("продать "))
def sell_command(m):
    """Обрабатывает команду продажи"""
    user = get_user(m)
    
    try:
        parts = m.text.split()
        if len(parts) < 2:
            raise ValueError
        
        idx = int(parts[1]) - 1
        process_sell_by_idx(m, idx)
    except:
        bot.send_message(m.chat.id, "❌ Используй: `продать [номер]`\nНомера смотри в `тл`")

def process_sell_by_idx(m, idx):
    """Продажа по индексу"""
    user = get_user(m)
    inv = user.get("inventory", [])
    
    if idx < 0 or idx >= len(inv):
        bot.send_message(m.chat.id, "❌ Неверный номер")
        return
    
    # Сортируем для соответствия нумерации
    sorted_inv = sorted(inv, key=lambda x: x['price'], reverse=True)
    
    if idx >= len(sorted_inv):
        bot.send_message(m.chat.id, "❌ Неверный номер")
        return
    
    item = sorted_inv[idx]
    
    # Находим и удаляем
    for i, inv_item in enumerate(inv):
        if (inv_item['name'] == item['name'] and 
            inv_item['price'] == item['price'] and 
            inv_item['cond'] == item['cond']):
            user["inventory"].pop(i)
            break
    
    user["balance"] += item['price']
    lvl_up = add_exp(user, 20)
    save_users()
    
    short_name = item['name'][:30] + "..." if len(item['name']) > 30 else item['name']
    msg = f"🤝 Ты продал *{short_name}* за *{item['price']:,}$*"
    
    if lvl_up:
        msg += "\n\n🏆 *УРОВЕНЬ ПОВЫШЕН!*"
    
    bot.send_message(m.chat.id, msg)

@bot.message_handler(func=lambda m: m.text and m.text.lower() == "флип")
def flip_command(m):
    simulate_flip(m)

@bot.message_handler(func=lambda m: m.text and m.text.lower() == "тл")
def inv_command(m):
    show_inventory(m)

@bot.message_handler(func=lambda m: m.text and m.text.lower() == "профиль")
def profile_command(m):
    show_profile(m)

@bot.message_handler(func=lambda m: m.text and m.text.lower() == "топ")
def top_command(m):
    show_top(m)

