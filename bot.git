        admin_text = "\n👑 *АДМИН ПАНЕЛЬ:* `/adminpanel`\n"
    
    # Создаем клавиатуру с кнопками
    markup = types.InlineKeyboardMarkup(row_width=2)
    markup.add(
        types.InlineKeyboardButton("🎰 Флип", callback_data="game_flip"),
        types.InlineKeyboardButton("🛒 Магазин", callback_data="game_shop"),
        types.InlineKeyboardButton("📱 Инвентарь", callback_data="game_inventory"),
        types.InlineKeyboardButton("👤 Профиль", callback_data="game_profile"),
        types.InlineKeyboardButton("🏆 Топ", callback_data="game_top"),
        types.InlineKeyboardButton("📁 Сейв", callback_data="game_save")
    )
    
    msg = (
        "📱 *ДОБРО ПОЖАЛОВАТЬ В СИМУЛЯТОР ПЕРЕКУПА!*\n"
        f"{admin_text}\n"
        "🎰 *ФЛИП:* раз в 3 часа\n"
        "🛒 *МАГАЗИН:* покупай телефоны и кейсы\n"
        "💰 *ПРОДАВАЙ:* команда `продать [номер]`\n\n"
        "🎮 *Более 100.000 уникальных моделей!*"
    )
    bot.send_message(m.chat.id, msg, reply_markup=markup)

@bot.message_handler(func=lambda m: m.text and m.text.lower() == "магазин")
def shop_text(m):
    show_shop_menu(m.chat.id)

