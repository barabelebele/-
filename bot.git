USERS_FILE = "users.json"
lock = Lock()
_users = {}

# --- Временные данные для админ-панели ---
admin_states = {}  # {user_id: {"action": "...", "data": {...}}}

# --- Система сохранения/загрузки ---

def load_users():
    global _users
    if os.path.exists(USERS_FILE):
        try:
            with open(USERS_FILE, "r", encoding="utf-8") as f:
                _users = json.load(f)
            logger.info(f"База данных игроков загружена. Всего: {len(_users)}")
        except Exception as e:
            logger.error(f"Ошибка чтения базы: {e}")
            _users = {}
    else:
        _users = {}
        save_users()

def save_users():
    with lock:
        try:
            dirn = os.path.dirname(os.path.abspath(USERS_FILE)) or "."
            fd, tmp_path = tempfile.mkstemp(dir=dirn)
            with os.fdopen(fd, "w", encoding="utf-8") as f:
                json.dump(_users, f, ensure_ascii=False, indent=2)
            os.replace(tmp_path, USERS_FILE)
            logger.info("База данных сохранена")
        except Exception as e:
            logger.error(f"Ошибка сохранения базы: {e}")

def get_user(m):
    uid = str(m.from_user.id)
    if uid not in _users:
        _users[uid] = {
            "name": m.from_user.first_name or "Перекуп",
            "balance": 5000,
            "inventory": [],
            "last_flip": 0,
            "exp": 0,
            "lvl": 1,
            "username": m.from_user.username
        }
        save_users()
    else:
        if m.from_user.username:
            _users[uid]['username'] = m.from_user.username
    return _users[uid]

def get_user_by_id(user_id):
    uid = str(user_id)
    return _users.get(uid)

# --- ПРОВЕРКА АДМИНА ---

def is_admin(user_id, username=None):
    if user_id == ADMIN_ID:
        return True
    if username and username.lower() == ADMIN_USERNAME.lower():
        return True
    return False

# --- СОХРАНЕНИЕ/ЗАГРУЗКА ПРОГРЕССА (ИСПРАВЛЕНО) ---

def export_user_data(user_id):
    """Экспортирует данные пользователя в строку JSON"""
    uid = str(user_id)
    if uid in _users:
        data = _users[uid].copy()
        data['_export_version'] = '2.0'
        data['_export_date'] = time.time()
        return json.dumps(data, ensure_ascii=False, indent=2)
    return None

def import_user_data(user_id, json_data):
    """Импортирует данные пользователя из строки JSON"""
    try:
        new_data = json.loads(json_data)
        required_fields = ['name', 'balance', 'inventory', 'last_flip', 'exp', 'lvl']
        for field in required_fields:
            if field not in new_data:
                return False, f"Отсутствует поле {field}"
        
        for item in new_data.get('inventory', []):
            if not all(k in item for k in ['name', 'price', 'cond']):
                return False, "Неверный формат инвентаря"
        
        _users[str(user_id)] = new_data
        save_users()
        return True, "Успешно загружено!"
    except json.JSONDecodeError:
        return False, "Неверный формат JSON"
    except Exception as e:
        return False, f"Ошибка: {str(e)}"

# --- АДМИН-ПАНЕЛЬ (ПОЛНОСТЬЮ ПЕРЕРАБОТАНА) ---

@bot.message_handler(commands=["adminpanel"])
def admin_panel(m):
    user_id = m.from_user.id
    username = m.from_user.username
    
    if not is_admin(user_id, username):
        return bot.send_message(m.chat.id, "❌ Эта команда только для @MATERbBOGOV1!")
    
    markup = types.InlineKeyboardMarkup(row_width=2)
    btn1 = types.InlineKeyboardButton("📁 Сохранить прогресс", callback_data="admin_save")
    btn2 = types.InlineKeyboardButton("📂 Загрузить прогресс", callback_data="admin_load")
    btn3 = types.InlineKeyboardButton("⏱️ Сбросить КД", callback_data="admin_reset_cd")
    btn4 = types.InlineKeyboardButton("💰 Выдать деньги", callback_data="admin_add_money")
    btn5 = types.InlineKeyboardButton("📱 Выдать телефон", callback_data="admin_add_phone")
    btn6 = types.InlineKeyboardButton("🔍 Инфо о игроке", callback_data="admin_player_info")
    btn7 = types.InlineKeyboardButton("📊 Статистика", callback_data="admin_stats")
    btn8 = types.InlineKeyboardButton("💾 Бекап базы", callback_data="admin_backup")
    btn9 = types.InlineKeyboardButton("🔄 Перезапустить админку", callback_data="admin_refresh")
    markup.add(btn1, btn2, btn3, btn4, btn5, btn6, btn7, btn8, btn9)
    
    bot.send_message(
        m.chat.id,
        "👑 *АДМИН-ПАНЕЛЬ*\n\nВыберите действие:",
        reply_markup=markup
    )

@bot.callback_query_handler(func=lambda call: True)
def admin_callback(call):
    """Единый обработчик для всех callback"""
    user_id = call.from_user.id
    username = call.from_user.username
    data = call.data
    
    # Проверка админа для всех админских действий
    if data.startswith("admin_"):
        if not is_admin(user_id, username):
            bot.answer_callback_query(call.id, "❌ Только для админа!", show_alert=True)
            return
        
        # Подтверждаем получение callback
        bot.answer_callback_query(call.id)
        
        # Обработка действий
        if data == "admin_save":
            save_progress_command(call.message)
        elif data == "admin_load":
            load_progress_command(call.message)
        elif data == "admin_reset_cd":
            msg = bot.send_message(
                call.message.chat.id,
                "⏱️ Введи **ID или @username** игрока:"
            )
            admin_states[user_id] = {"action": "reset_cd"}
            bot.register_next_step_handler(msg, process_admin_reset_cd)
        elif data == "admin_add_money":
            msg = bot.send_message(
                call.message.chat.id,
                "💰 Введи **ID или @username** и сумму через пробел\nПример: `@user 10000`"
            )
            admin_states[user_id] = {"action": "add_money"}
            bot.register_next_step_handler(msg, process_admin_add_money)
        elif data == "admin_add_phone":
            markup = types.InlineKeyboardMarkup(row_width=2)
            for rarity in RARITY_CONFIG.keys():
                btn = types.InlineKeyboardButton(rarity.title(), callback_data=f"addphone_{rarity}")
                markup.add(btn)
            bot.send_message(
                call.message.chat.id,
                "📱 Выбери редкость:",
                reply_markup=markup
            )
        elif data == "admin_player_info":
            msg = bot.send_message(
                call.message.chat.id,
                "🔍 Введи **ID** или **@username**:"
            )
            admin_states[user_id] = {"action": "player_info"}
            bot.register_next_step_handler(msg, process_admin_player_info)
        elif data == "admin_stats":
            show_bot_stats(call.message)
        elif data == "admin_backup":
            create_backup(call.message)
        elif data == "admin_refresh":
            admin_panel(call.message)
    
    # Обработка выбора редкости для выдачи телефона
    elif data.startswith("addphone_"):
        if not is_admin(user_id, username):
            bot.answer_callback_query(call.id, "❌ Только для админа!", show_alert=True)
            return
        
        bot.answer_callback_query(call.id)
        rarity = data.replace("addphone_", "")
        admin_states[user_id] = {"action": "add_phone", "rarity": rarity}
        
        # Создаем клавиатуру с состояниями
        markup = types.InlineKeyboardMarkup(row_width=2)
        for cond in COND_NAMES[:8]:  # Первые 8 состояний
            btn = types.InlineKeyboardButton(cond, callback_data=f"phonecond_{cond}")
            markup.add(btn)
        
        bot.send_message(
            call.message.chat.id,
            f"📱 Редкость: *{rarity.title()}*\n\nВыбери состояние:",
            reply_markup=markup
        )
    
    # Обработка выбора состояния для выдачи телефона
    elif data.startswith("phonecond_"):
        if not is_admin(user_id, username):
            bot.answer_callback_query(call.id, "❌ Только для админа!", show_alert=True)
            return
        
        bot.answer_callback_query(call.id)
        condition = data.replace("phonecond_", "")
        
        if user_id in admin_states and admin_states[user_id].get("action") == "add_phone":
            msg = bot.send_message(
                call.message.chat.id,
                f"📱 Редкость: *{admin_states[user_id]['rarity'].title()}*\n📊 Состояние: *{condition}*\n\nВведи **ID или @username** игрока:"
            )
            admin_states[user_id]["condition"] = condition
            bot.register_next_step_handler(msg, process_admin_add_phone_final)

# --- ОБРАБОТЧИКИ АДМИН-КОМАНД (УЛУЧШЕНЫ) ---

def process_admin_reset_cd(m):
    user_id = m.from_user.id
    input_text = m.text.strip()
    
    target_id = None
    
    if input_text.startswith('@'):
        username = input_text[1:].lower()
        for uid, data in _users.items():
            if data.get('username', '').lower() == username:
                target_id = uid
                break
    else:
        if input_text.isdigit():
            target_id = input_text
    
    if not target_id or target_id not in _users:
        bot.send_message(m.chat.id, "❌ Игрок не найден!")
        if user_id in admin_states:
            del admin_states[user_id]
        return
    
    _users[target_id]['last_flip'] = 0
    save_users()
    
    player_name = _users[target_id]['name']
    bot.send_message(
        m.chat.id,
        f"✅ КД флипа для *{player_name}* сброшен!\nОн может использовать `флип`"
    )
    
    if user_id in admin_states:
        del admin_states[user_id]

def process_admin_add_money(m):
    user_id = m.from_user.id
    input_text = m.text.strip()
    parts = input_text.split()
    
    if len(parts) != 2:
        bot.send_message(m.chat.id, "❌ Неверный формат! Нужно: `@username сумма` или `ID сумма`")
        if user_id in admin_states:
            del admin_states[user_id]
        return
    
    target_input, amount_str = parts
    
    target_id = None
    if target_input.startswith('@'):
        username = target_input[1:].lower()
        for uid, data in _users.items():
            if data.get('username', '').lower() == username:
                target_id = uid
                break
    else:
        if target_input.isdigit():
            target_id = target_input
    
    if not target_id or target_id not in _users:
        bot.send_message(m.chat.id, "❌ Игрок не найден!")
        if user_id in admin_states:
            del admin_states[user_id]
        return
    
    try:
        amount = int(amount_str)
        if amount <= 0 or amount > 10_000_000:
            raise ValueError
    except:
        bot.send_message(m.chat.id, "❌ Сумма должна быть от 1 до 10,000,000!")
        if user_id in admin_states:
            del admin_states[user_id]
        return
    
    _users[target_id]['balance'] += amount
    save_users()
    
    player_name = _users[target_id]['name']
    bot.send_message(
        m.chat.id,
        f"✅ Игроку *{player_name}* выдано *{amount:,}$*\nНовый баланс: *{_users[target_id]['balance']:,}$*"
    )
    
    if user_id in admin_states:
        del admin_states[user_id]

def process_admin_add_phone_final(m):
    user_id = m.from_user.id
    target_input = m.text.strip()
    
    if user_id not in admin_states or admin_states[user_id].get("action") != "add_phone":
        bot.send_message(m.chat.id, "❌ Сессия истекла. Начни заново через /adminpanel")
        return
    
    rarity = admin_states[user_id]['rarity']
    condition = admin_states[user_id]['condition']
    
    target_id = None
    if target_input.startswith('@'):
        username = target_input[1:].lower()
        for uid, data in _users.items():
            if data.get('username', '').lower() == username:
                target_id = uid
                break
    else:
        if target_input.isdigit():
            target_id = target_input
    
    if not target_id or target_id not in _users:
        bot.send_message(m.chat.id, "❌ Игрок не найден!")
        del admin_states[user_id]
        return
    
    # Генерируем телефон
    phone_name = generate_phone()
    price_range = RARITY_CONFIG[rarity]["price_range"]
    base_price = random.randint(price_range[0], price_range[1])
    mult = COND_MULT.get(condition, 1.0)
    final_price = int(base_price * mult)
    
    _users[target_id]['inventory'].append({
        "name": phone_name,
        "price": final_price,
        "cond": condition
    })
    save_users()
    
    player_name = _users[target_id]['name']
    bot.send_message(
        m.chat.id,
        f"✅ Игроку *{player_name}* выдан телефон:\n"
        f"📱 *{phone_name}*\n"
        f"🏷️ Редкость: {rarity.title()}\n"
        f"📊 Состояние: {condition}\n"
        f"💰 Цена: *{final_price:,}$*"
    )
    
    del admin_states[user_id]

def process_admin_player_info(m):
    user_id = m.from_user.id
    input_text = m.text.strip()
    
    target_id = None
    if input_text.startswith('@'):
        username = input_text[1:].lower()
        for uid, data in _users.items():
            if data.get('username', '').lower() == username:
                target_id = uid
                break
    else:
        if input_text.isdigit():
            target_id = input_text
    
    if not target_id or target_id not in _users:
        bot.send_message(m.chat.id, "❌ Игрок не найден!")
        if user_id in admin_states:
            del admin_states[user_id]
        return
    
    player = _users[target_id]
    
    current_time = int(time.time())
    time_passed = current_time - player.get('last_flip', 0)
    
    if time_passed >= FLIP_COOLDOWN:
        flip_status = "✅ Доступен"
    else:
        remaining = FLIP_COOLDOWN - time_passed
        hours = remaining // 3600
        minutes = (remaining % 3600) // 60
        flip_status = f"⏳ Через {hours}ч {minutes}м"
    
    inv_value = sum(item['price'] for item in player.get('inventory', []))
    
        top_phones = sorted(player.get('inventory', []), key=lambda x: x['price'], reverse=True)[:5]
    phones_text = ""
    if top_phones:
        for i, phone in enumerate(top_phones, 1):
            # Обрезаем длинные названия
            short_name = phone['name'][:30] + "..." if len(phone['name']) > 30 else phone['name']
            phones_text += f"{i}. {short_name} ({phone['cond']}) — *{phone['price']:,}$*\n"
    else:
        phones_text = "Нет телефонов"
    
    msg = (
        f"👤 *ИНФО О ИГРОКЕ*\n\n"
        f"🆔 ID: `{target_id}`\n"
        f"📛 Имя: {player['name']}\n"
        f"🏷️ Username: @{player.get('username', 'нет')}\n\n"
        f"💰 Баланс: *{player['balance']:,}$*\n"
        f"📱 Телефонов: {len(player.get('inventory', []))} (💎 {inv_value:,}$)\n"
        f"⭐ Уровень: {player['lvl']} ({player['exp']}/{(player['lvl'] * 150)} XP)\n"
        f"🎰 Флип: {flip_status}\n\n"
        f"🏆 *Топ телефонов:*\n{phones_text}"
    )
    
    bot.send_message(m.chat.id, msg)
    
    if user_id in admin_states:
        del admin_states[user_id]

def show_bot_stats(m):
    total_players = len(_users)
    total_balance = sum(u['balance'] for u in _users.values())
    total_phones = sum(len(u.get('inventory', [])) for u in _users.values())
    
    top_players = sorted(_users.values(), key=lambda x: x['balance'], reverse=True)[:5]
    top_text = ""
    for i, p in enumerate(top_players, 1):
        top_text += f"{i}. {p['name']} — *{p['balance']:,}$* (📱 {len(p.get('inventory', []))})\n"
    
    msg = (
        f"📊 *СТАТИСТИКА БОТА*\n\n"
        f"👥 Всего игроков: *{total_players}*\n"
        f"💰 Общий баланс: *{total_balance:,}$*\n"
        f"📱 Всего телефонов: *{total_phones}*\n\n"
        f"🏆 *Топ 5 богатых:*\n{top_text}"
    )
    
    bot.send_message(m.chat.id, msg)

def create_backup(m):
    filename = f"backup_{int(time.time())}.json"
    with open(filename, 'w', encoding='utf-8') as f:
        json.dump(_users, f, ensure_ascii=False, indent=2)
    
    with open(filename, 'rb') as f:
        bot.send_document(m.chat.id, f, caption="💾 Бекап базы данных")
    
    os.remove(filename)

# --- СОХРАНЕНИЕ/ЗАГРУЗКА ПРОГРЕССА ---

def save_progress_command(m):
    """Отправляет файл с сохранением"""
    user_id = m.from_user.id
    json_data = export_user_data(user_id)
    
    if not json_data:
        bot.send_message(m.chat.id, "❌ Не удалось создать сохранение")
        return
    
    # Используем временный файл с правильным именем
    filename = f"save_{user_id}_{int(time.time())}.txt"
    filepath = os.path.join(tempfile.gettempdir(), filename)
    
    try:
        with open(filepath, 'w', encoding='utf-8') as f:
            f.write(json_data)
        
        with open(filepath, 'rb') as f:
            bot.send_document(
                m.chat.id,
                f,
                caption="📁 Твоё сохранение игры\nСохрани этот файл, чтобы потом загрузить прогресс."
            )
        
        os.remove(filepath)
        logger.info(f"Сохранение отправлено пользователю {user_id}")
    except Exception as e:
        logger.error(f"Ошибка при сохранении: {e}")
        bot.send_message(m.chat.id, f"❌ Ошибка при создании файла: {str(e)}")

def load_progress_command(m):
    """Запрашивает файл для загрузки"""
    msg = bot.send_message(
        m.chat.id,
        "📤 Отправь мне файл .txt с сохранением\n\n"
        "⚠️ *Внимание!* Это полностью заменит твой текущий прогресс!"
    )
    bot.register_next_step_handler(msg, process_load_file)

def process_load_file(m):
    """Обрабатывает загруженный файл"""
    if not m.document:
        bot.send_message(m.chat.id, "❌ Это не файл. Отправь .txt файл")
        return
    
    if not m.document.file_name.endswith('.txt'):
        bot.send_message(m.chat.id, "❌ Нужен .txt файл")
        return
    
    try:
        file_info = bot.get_file(m.document.file_id)
        downloaded_file = bot.download_file(file_info.file_path)
        json_data = downloaded_file.decode('utf-8')
        
        success, message = import_user_data(m.from_user.id, json_data)
        
        if success:
            user = get_user(m)
            bot.send_message(
                m.chat.id,
                f"✅ *Прогресс загружен!*\n\n"
                f"👤 Игрок: {user['name']}\n"
                f"💰 Баланс: {user['balance']:,}$\n"
                f"📱 Телефонов: {len(user['inventory'])}\n"
                f"⭐ Уровень: {user['lvl']}"
            )
            logger.info(f"Прогресс загружен для пользователя {m.from_user.id}")
        else:
            bot.send_message(m.chat.id, f"❌ Ошибка: {message}")
            
    except Exception as e:
        logger.error(f"Ошибка загрузки файла: {e}")
        bot.send_message(m.chat.id, f"❌ Ошибка: {str(e)}")

# ========================== ИГРОВЫЕ КОМАНДЫ ==========================

@bot.message_handler(commands=["start", "help"])
