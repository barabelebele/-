def generate_case_phone():
    """Генерирует телефон для кейса"""
    name = generate_phone()
    base_price = random.randint(300, 25000)
    condition = random.choice(COND_NAMES)
    mult = COND_MULT[condition]
    final_price = int(base_price * mult)
    if final_price > 35000:
        final_price = random.randint(15000, 35000)
    return name, final_price, condition

